<!DOCTYPE html>
<html>
<head>
<title>Bhola Store</title>

<style>

body{
margin:0;
font-family:Arial;
background:#f2f2f2;
}

header{
background:#0a7f2e;
color:white;
padding:20px;
text-align:center;
font-size:26px;
}

.products{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
padding:40px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
width:200px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
