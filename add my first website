}

.card img{
width:100%;
border-radius:10px;
}

button{
padding:10px 20px;
background:#0a7f2e;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

</style>

</head>

<body>

<header>
Bhola Online Store
</header>

<div class="products">

<div class="card">
<img src="https://picsum.photos/200/150">
<h3>Milk</h3>
<p>₹60</p>
<a href="https://example.com/product1">
<button>Order Now</button>
</a>
</div>

<div class="card">
<img src="https://picsum.photos/201/150">
<h3>Bread</h3>
<p>₹40</p>
<a href="https://example.com/product2">
<button>Order Now</button>
</a>
</div>

<div class="card">
<img src="https://picsum.photos/202/150">
<h3>Banana</h3>
<p>₹30</p>
<a href="https://example.com/product3">
<button>Order Now</button>
</a>
</div>

</div>

</body>
</html>
